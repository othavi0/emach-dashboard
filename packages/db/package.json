{
  "name": "@emach/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:sync": "drizzle-kit push && bun run db:apply-triggers",
    "db:studio": "drizzle-kit studio",
    "db:apply-triggers": "bun run scripts/apply-triggers.ts",
    "db:seed-demo": "bun run scripts/seed-demo.ts",
    "db:reset-demo": "bun run scripts/reset-demo.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@emach/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.17.1"
  },
  "devDependencies": {
    "@emach/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^6.0.3"
  }
}
